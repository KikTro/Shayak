rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ───────── Helpers ─────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOrganizer() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['organizer', 'admin'];
    }

    // ───────── USERS ─────────
    match /users/{userId} {
      allow read: if true;                       // Public profiles
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ───────── EVENTS ─────────
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && (resource.data.organizer.uid == request.auth.uid
            || isAdmin()
            || request.auth.uid in resource.data.coHosts
            // Allow attendees to RSVP (only mutate attendees/pendingApprovals)
            || (request.resource.data.diff(resource.data)
                  .affectedKeys()
                  .hasOnly(['attendees','pendingApprovals','updatedAt'])));
      allow delete: if resource.data.organizer.uid == request.auth.uid || isAdmin();
    }

    // ───────── CHATS ─────────
    match /chats/{roomId} {
      allow read: if isSignedIn()
        && (resource.data.isPublic == true
            || request.auth.uid in resource.data.participants
            || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && (request.auth.uid in resource.data.participants || isAdmin());
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && (get(/databases/$(database)/documents/chats/$(roomId)).data.isPublic == true
              || request.auth.uid in get(/databases/$(database)/documents/chats/$(roomId)).data.participants
              || isAdmin());
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && (get(/databases/$(database)/documents/chats/$(roomId)).data.isPublic == true
              || request.auth.uid in get(/databases/$(database)/documents/chats/$(roomId)).data.participants);
        allow update: if isSignedIn()
          && resource.data.senderId == request.auth.uid;
        allow delete: if isSignedIn()
          && (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    // ───────── AGENT ACTIONS ─────────
    match /agentActions/{actionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();       // Cloud Functions use admin SDK (bypasses rules)
    }

    // ───────── INTRO REQUESTS ─────────
    match /introRequests/{requestId} {
      allow read: if isSignedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid
            || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ───────── DEVELOPER GRAPH ─────────
    match /developerGraph/{nodeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();       // Cloud Functions use admin SDK
    }

    // Fallback deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
